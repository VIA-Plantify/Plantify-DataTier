{
  "name": "C# Data Dev",
  "dockerComposeFile": "../docker-compose.dev.yml",
  "service": "datadev",
  "workspaceFolder": "/workspace",
  "shutdownAction": "none",
  "updateRemoteUserUID": false,
  "initializeCommand": "docker network inspect plantify-network >/dev/null 2>&1 || docker network create plantify-network",
  "postCreateCommand": "chmod +x /workspace/.scripts/*.sh && bash /workspace/.scripts/setup-dev.sh",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit"
      ]
    }
  }
}